---
import { ClientRouter } from "astro:transitions";
import ChoiceList from "@/components/ChoiceList.astro";
import DialogBox from "@/components/DialogBox.astro";
import Leaderboard from "@/components/Leaderboard.astro";
import PixelProgress from "@/components/PixelProgress.astro";
import SceneStage from "@/components/SceneStage.astro";
import { validateSequentialContent } from "@/lib/game/engine";
import type { GameContent } from "@/lib/game/types";

interface Props {
  content: GameContent;
  locale: string;
}

const { content, locale } = Astro.props;
const contentErrors = validateSequentialContent(content);

if (contentErrors.length > 0) {
  throw new Error(`遊戲內容不符合流程規格：${contentErrors.join("；")}`);
}

const serializedContent = JSON.stringify(content).replaceAll("<", "\\u003c");
const BASE = import.meta.env.BASE_URL;

function fmtDay(template: string, order: number): string {
  return template.replace("{dayOrder}", String(order));
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={content.meta.subtitle} />
    <title>{content.meta.title}</title>
    <ClientRouter />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-EZSNTNY74B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EZSNTNY74B');
    </script>
  </head>
  <body>
    <div id="settings-panel" class="settings-panel" hidden role="dialog" aria-modal="true" aria-labelledby="settings-title">
      <div class="settings-modal">
        <div class="settings-titlebar">
          <div class="window-controls" aria-hidden="true">
            <span class="window-dot"></span>
            <span class="window-dot"></span>
            <span class="window-dot"></span>
          </div>
          <span class="settings-title" id="settings-title">{content.ui.settingsTitle}</span>
          <button class="settings-close-btn" id="settings-close" type="button" aria-label={content.ui.closeButtonLabel}>✕</button>
        </div>
        <div class="settings-body">
          <button class="settings-action-btn settings-action-btn--warning" id="settings-restart" type="button">
            <img class="menu-btn-icon" src={`${BASE}assets/icons/icon-restart.svg`} alt="" aria-hidden="true" />
            <span>{content.ui.settingsRestartButton}</span>
          </button>
          <button class="settings-action-btn settings-action-btn--info" id="settings-help" type="button">
            <img class="menu-btn-icon" src={`${BASE}assets/icons/icon-help.svg`} alt="" aria-hidden="true" />
            <span>{content.ui.settingsHelpButton}</span>
          </button>
          <button class="settings-action-btn settings-action-btn--home" id="settings-home" type="button">
            <img class="menu-btn-icon" src={`${BASE}assets/icons/icon-home.svg`} alt="" aria-hidden="true" />
            <span>{content.ui.settingsHomeButton}</span>
          </button>
        </div>
        <footer class="settings-footer">
          <p class="settings-copyright">
            © 2026 <a class="settings-link" href="https://elvislo.tw" target="_blank" rel="noopener noreferrer">ElvisLo</a> {content.ui.settingsCopyrightText}
          </p>
        </footer>
      </div>
    </div>

    {content.welcome && (
      <div id="welcome-overlay" class="welcome-overlay" role="dialog" aria-modal="true" aria-labelledby="welcome-title">
        <div class="welcome-modal">
          <h2 class="welcome-title" id="welcome-title">{content.welcome.title}</h2>
          <div class="welcome-body">{content.welcome.body}</div>
          <button id="welcome-confirm" class="welcome-confirm-btn" type="button">
            {content.welcome.confirmButton}
          </button>
        </div>
      </div>
      <script>
        {/* sessionStorage：同一分頁只顯示一次 */}
        const overlay = document.getElementById('welcome-overlay');
        if (overlay) {
          if (sessionStorage.getItem('welcome-seen')) {
            overlay.hidden = true;
          }
          document.getElementById('welcome-confirm')?.addEventListener('click', () => {
            overlay.hidden = true;
            sessionStorage.setItem('welcome-seen', '1');
          });
        }
      </script>
    )}
    <div class="device-overlay landscape-overlay" role="alert">
      <p class="device-overlay__msg">{content.ui.landscapeOverlayText}</p>
    </div>
    <div class="device-overlay desktop-overlay" role="alert">
      <p class="device-overlay__msg">{content.ui.desktopOverlayText}</p>
    </div>
    <div id="day-transition-overlay" class="day-transition-overlay" hidden aria-hidden="true">
      <div class="day-transition-window">
        <div class="day-transition-titlebar">
          <div class="day-transition-dots" aria-hidden="true">
            <span class="day-transition-dot"></span>
            <span class="day-transition-dot"></span>
            <span class="day-transition-dot"></span>
          </div>
        </div>
        <div class="day-transition-body">
          <p class="day-transition-label" id="day-transition-label"></p>
        </div>
      </div>
    </div>
    <main class="app-shell">
      <div class="game-window" data-view-transition>
        <header class="title-bar">
          <div class="title-meta">
            <div class="window-controls" aria-hidden="true">
              <span class="window-dot"></span>
              <span class="window-dot"></span>
              <span class="window-dot"></span>
            </div>
            <h1 class="brand">{content.meta.title}</h1>
          </div>
          <button class="settings-button" id="settings-button" type="button" aria-label={content.ui.settingsButtonLabel}>
            <img class="settings-btn-icon" src={`${BASE}assets/icons/icon-settings.svg`} alt="" aria-hidden="true" />
          </button>
        </header>

        <section class="status-strip" aria-label={content.ui.statusBarLabel}>
          <div class="stat-box">
            <span class="stat-label">{content.ui.playerStatLabel}</span>
            <span class="stat-value" id="player-name-label">{content.ui.defaultPlayerName}</span>
          </div>
          <PixelProgress progressBarLabel={content.ui.progressBarLabel} scoreLabel={content.ui.scoreLabel} totalMax={content.points.totalMax} />
          <div class="stat-box">
            <span class="stat-label" id="route-label">{fmtDay(content.ui.dayLabelFormat, 1)}</span>
            <span class="stat-value" id="stage-title">{content.ui.namePromptTitle}</span>
          </div>
        </section>

        <div class="main-grid">
          <SceneStage />
          <DialogBox />
          <aside class="side-panel" id="side-panel" hidden>
            <ChoiceList choiceAreaLabel={content.ui.choiceAreaLabel} />
            <Leaderboard
              resultTitle={content.ending.title}
              totalMax={content.points.totalMax}
              spMax={content.points.spMax}
              submitButtonText={content.ui.submitScoreButton}
            />
          </aside>
        </div>

        <footer class="footer-bar" id="footer-bar" hidden>
          <button class="pixel-button" id="next-stage-button" type="button" disabled>{content.ui.nextButton}</button>
        </footer>
      </div>
    </main>
    <script is:inline type="application/json" id="game-content" set:html={serializedContent}></script>
    <script>
      import "@/scripts/game";
    </script>
  </body>
</html>
