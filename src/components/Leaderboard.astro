---
---

<section class="result-panel" id="result-panel" hidden aria-labelledby="result-title">
  <h2 id="result-title">三日研究成果</h2>
  <p id="result-summary"></p>
  <div class="result-grid">
    <div class="stat-box">
      <span class="stat-label">Day 1</span>
      <span class="stat-value" id="result-day1">0 / 100</span>
    </div>
    <div class="stat-box">
      <span class="stat-label">Day 2</span>
      <span class="stat-value" id="result-day2">0 / 100</span>
    </div>
    <div class="stat-box">
      <span class="stat-label">Day 3</span>
      <span class="stat-value" id="result-day3">0 / 100</span>
    </div>
  </div>
  <form class="leaderboard-form" id="leaderboard-form">
    <button class="pixel-button" type="submit" id="submit-score-button">送出排行榜</button>
    <p class="leaderboard-note" id="leaderboard-status"></p>
  </form>
  <ol class="leaderboard-list" id="leaderboard-list"></ol>
</section>
