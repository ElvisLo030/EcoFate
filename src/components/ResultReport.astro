---
interface Props {
  resultTitle: string;
  totalMax: number;
  spMax: number;
}
const { resultTitle, totalMax, spMax } = Astro.props;
---

<section class="result-panel" id="result-panel" hidden aria-labelledby="result-title">
  <div class="report-header">
    <span class="report-kicker">RESULT REPORT</span>
    <h2 id="result-title">{resultTitle}</h2>
    <p id="result-summary"></p>
  </div>
  <div class="report-identity">
    <div class="stat-box">
      <span class="stat-label">暱稱</span>
      <span class="stat-value" id="result-player-name">未知的引導者</span>
    </div>
    <div class="stat-box">
      <span class="stat-label">通關耗時</span>
      <span class="stat-value" id="result-elapsed-time">00:00</span>
    </div>
    <div class="stat-box">
      <span class="stat-label">結局</span>
      <span class="stat-value" id="result-ending-name">Ending</span>
    </div>
  </div>
  <div class="result-grid">
    <div class="stat-box">
      <span class="stat-label">主線積分</span>
      <span class="stat-value" id="result-total">0 / {totalMax}</span>
    </div>
    <div class="stat-box">
      <span class="stat-label">隱藏加分</span>
      <span class="stat-value" id="result-sp">0 / {spMax}</span>
    </div>
  </div>
  <section class="group-stats" aria-label="分組統計">
    <h3>分組統計</h3>
    <div class="group-stat-list" id="result-group-stats"></div>
  </section>
  <div class="result-actions">
    <button class="pixel-button" type="button" id="result-home-button">回到主畫面</button>
  </div>
</section>
