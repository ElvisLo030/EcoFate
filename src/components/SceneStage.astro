<section class="scene-panel" aria-labelledby="stage-title">
  <div class="scene-header">
    <div class="scene-label">
      <span class="scene-kicker" id="day-theme">Day 1｜源頭減量</span>
      <h2 class="scene-title" id="stage-title">永續生活研究社</h2>
    </div>
    <div class="scene-score">
      <span id="day-score-label">本日分數</span>
      <div id="day-score">0 / 100</div>
    </div>
  </div>
  <div class="scene-visual" id="scene-visual" data-bg="club">
    <img
      class="character-portrait"
      id="character-portrait"
      src="assets/characters/system.svg"
      alt="系統立繪"
      width="330"
      height="390"
    />
  </div>
</section>
